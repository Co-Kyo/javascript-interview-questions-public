#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Prevent committing markdown files whose only changes are line ending differences.
# Use NUL-delimited paths and disable path quoting for non-ASCII filenames.
git -c core.quotepath=false diff --cached --name-only -z --diff-filter=ACMRT -- '*.md' | while IFS= read -r -d '' file; do
  if [ -z "$(git -c core.quotepath=false diff --cached --ignore-space-at-eol -- "$file")" ]; then
    echo "Restoring eol-only change: $file"
    git restore --staged -- "$file"
    git checkout -- "$file"
  fi
done
